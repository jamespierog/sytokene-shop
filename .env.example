# ═══════════════════════════════════════════════════════
# SYTO SHOP — Environment Variables
# ═══════════════════════════════════════════════════════
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.

# ─── MoneyDevKit (Bitcoin Lightning Payments) ───
# Get these by running: npx @moneydevkit/create
# Or from your dashboard at moneydevkit.com
MDK_ACCESS_TOKEN=your_mdk_api_key
MDK_MNEMONIC=your_mdk_mnemonic_keep_this_secret

# Webhook signing secret (set up at: Dashboard → Apps → Webhooks → Add Endpoint)
# Point the webhook URL to: https://yourdomain.com/api/webhooks/mdk
# Subscribe to event: checkout.completed
MDK_WEBHOOK_SECRET=whsec_your_secret_here

# ─── Firebase (Client-side — these are safe to expose) ───
# Get these from: Firebase Console → Project Settings → General → Your apps → Web app
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abcdef

# ─── Firebase Admin (Server-side — KEEP SECRET) ───
# Get this from: Firebase Console → Project Settings → Service Accounts → Generate New Private Key
# The downloaded JSON file contains all these values.
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ─── Site URL ───
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Email Delivery (Optional — for sending download links after purchase) ───
# If you use Gmail: enable 2FA, then create an App Password at
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=sytokene@yourdomain.com
